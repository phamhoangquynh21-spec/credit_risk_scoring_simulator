{
  "title": "Credit Risk Scoring — Service & Drift",
  "uid": "credit-risk-monitoring",
  "schemaVersion": 39,
  "time": { "from": "now-24h", "to": "now" },
  "refresh": "1m",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate (req/s)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (method, status_class) (rate(http_requests_total[5m]))",
          "legendFormat": "{{method}} {{status_class}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "p95 latency (s)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, method) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{method}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Feature drift PSI (drift_psi.<feature>)",
      "description": "PSI per feature from src/monitoring/drift.py, persisted to the monitoring_metrics table (metric = drift_psi.<feature>). Thresholds: warn 0.1, alert 0.2.",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS_POSTGRES}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT period AS time, metric, value FROM monitoring_metrics WHERE metric LIKE 'drift_psi.%' ORDER BY period"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.2 }
            ]
          }
        },
        "overrides": []
      }
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] }
}
